WHOLEMOLECULES ENTITY0=793-892
hc: CENTER ATOMS=793-892     # H₂质心（索引需准确）
dists: DISTANCES GROUPA=hc GROUPB=793-892  HIGHEST LOWMEM
uwall: UPPER_WALLS ARG=dists.highest AT=0.78 KAPPA=5000.0   # 维持气泡紧凑性

# ==================== 第二部分：驱动脱离的元动力学（新增Z方向） ====================
# 定义气泡质心坐标（X、Y控制迁移，Z控制脱离表面）
p: POSITION ATOM=hc NOPBC 

# ==================== 输出监控 ====================
PRINT ARG=dists.highest,p.z STRIDE=10 FILE=COLVAR
FLUSH STRIDE=10
